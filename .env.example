# Docker Compose environment (copy to .env: cp .env.example .env)

IRS_PORT=3000

# LM Studio on the host machine (used by the ML scoring service)
LM_STUDIO_URL=http://host.docker.internal:1234

# Laravel API (used inside the api container)
APP_NAME="Intelligent Recruitment System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:3000

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

CV_SCORING_SERVICE_URL=http://ml:8001

FILESYSTEM_DISK=local
